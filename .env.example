# AI 超级智能体 - 环境变量示例
# 复制为 .env 或在系统中设置

# ── 百炼 / 通义（必填，默认模型）──
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# ── DeepSeek（可选）──
DEEPSEEK_ENABLED=false
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# ── 豆包 / 火山引擎（可选，OpenAI 兼容接口）──
DOUBAO_ENABLED=false
DOUBAO_API_KEY=xxxxxxxxxxxxxxxx
DOUBAO_MODEL=doubao-pro-32k
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com
DOUBAO_COMPLETIONS_PATH=/api/v3/chat/completions

# ── Ollama 本地（可选）──
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434

# ── 联网搜索（可选）──
SEARCH_API_KEY=

# ── 数据库 ──
PG_HOST=localhost
PG_PORT=5432
PG_DB=ai_super_agent
PG_USER=postgres
PG_PASSWORD=postgres

# ── MCP ──
MCP_ENABLED=false

# ── Stripe 支付（可选）──
STRIPE_ENABLED=true
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_8x27sLebYdZCdz65dD1oI00

# ── 国内支付（微信 / 支付宝）──
DOMESTIC_PAY_ENABLED=true
PAY_NOTIFY_BASE_URL=http://localhost:8080
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=
WECHAT_APP_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
WECHAT_MCH_SERIAL=
WECHAT_PRIVATE_KEY_PATH=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_SANDBOX=true
